   "source": [
    "import torch\n",
    "\n",
    "# Create a 1D tensor of size 3\n",
    "x = torch.tensor([10, 20, 30])  # Shape: [3]\n",
    "\n",
    "# Add a fake dimension to make it 2D\n",
    "x = x.unsqueeze(0)              # Shape: [1, 3]\n",
    "\n",
    "# Apply expand\n",
    "y = x.expand(1, -1)             # Shape: [1, 3]\n",
    "print(y)\n"
   ]
